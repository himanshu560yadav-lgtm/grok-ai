<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:fillViewport="true">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🍯 Honey AI"
        android:textSize="28sp"
        android:textColor="#FFD700"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="32dp"/>

    <!-- API Key Section -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="API Key (Gemini ya NVIDIA NIM)"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/etApiKey"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="AIza... ya nvapi-... paste karo"
        android:inputType="textVisiblePassword"
        android:textColor="#FFFFFF"
        android:textColorHint="#888888"
        android:background="@drawable/edit_text_border"
        android:padding="12dp"
        android:layout_marginBottom="8dp"/>

    <Button
        android:id="@+id/btnLoadModels"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Free Models Load Karo"
        android:backgroundTint="#333333"
        android:textColor="#FFD700"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvProviderStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#AAAAAA"
        android:textSize="13sp"
        android:layout_marginBottom="8dp"/>

    <!-- Dynamically populated model buttons go here -->
    <LinearLayout
        android:id="@+id/modelListContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="24dp"/>

    <!-- Task Section -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Task"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/etTask"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Task likho ya bolo..."
        android:textColor="#FFFFFF"
        android:textColorHint="#888888"
        android:background="@drawable/edit_text_border"
        android:padding="12dp"
        android:minLines="3"
        android:gravity="top"
        android:layout_marginBottom="12dp"/>

    <!-- Mic Button -->
    <Button
        android:id="@+id/btnMic"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🎤 Bolo"
        android:backgroundTint="#1A1A2E"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="24dp"/>

    <!-- Start / Stop Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">

        <Button
            android:id="@+id/btnStart"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="▶ Start"
            android:backgroundTint="#006400"
            android:textColor="#FFFFFF"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btnStop"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⏹ Stop"
            android:backgroundTint="#8B0000"
            android:textColor="#FFFFFF"
            android:layout_marginStart="8dp"
            android:enabled="false"/>

    </LinearLayout>

    <!-- Status -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⏹ Agent Stopped"
        android:textColor="#AAAAAA"
        android:textSize="16sp"
        android:gravity="center"/>

</LinearLayout>
</ScrollView>
